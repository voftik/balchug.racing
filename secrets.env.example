# Шаблон /etc/balchug/secrets.env — секреты сервисов каталога записей.
# Скопируйте на сервер: /etc/balchug/secrets.env (chmod 600, владелец root).
# Файл читают systemd-юниты (EnvironmentFile) и cron-джобы (source).

# --- S3-хранилище записей (Beget Cloud или совместимое) ---
S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
S3_REGION=ru1
S3_BUCKET=<имя-бакета>
S3_ACCESS_KEY=<access-key>
S3_SECRET_KEY=<secret-key>

# --- каталог записей ---
CATALOG_DB=/var/lib/balchug/catalog.db
ADMIN_TOKEN=<токен-редактирования-каталога>
PRESIGN_TTL=21600

# --- управление инженерными сессиями live timing ---
# Отдельный секрет. Не равен ADMIN_TOKEN, не выдаётся endpoint /api/boris и не
# попадает в статический frontend. Нужен только для защищённых timing write API.
ENGINEER_TOKEN=<длинный-случайный-токен-инженера>

# --- аннотатор записей (опционально; без ключа работает календарная аннотация) ---
# Любой OpenAI-совместимый vision-API (OpenRouter, OpenAI, ...).
#LLM_API_KEY=<api-key>
#LLM_MODEL=google/gemini-3.5-flash
#LLM_BASE_URL=https://openrouter.ai/api/v1
# Если провайдер блокирует IP сервера (напр. OpenRouter из РФ) — исходящий прокси:
#LLM_PROXY=http://user:pass@proxy-host:port
# Локальный Wireproxy для OpenRouter (см. server/wireproxy.conf.example):
#LLM_PROXY=http://127.0.0.1:25345

# --- склейщик сессий записи (опционально, дефолты разумные) ---
# Максимальный зазор между кусками одной трансляции, минуты
# (обрывы эфира внутри гонки бывают до ~50 мин):
#SESSION_GAP_MIN=60
